{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "una-editor": ["../src/index.ts"]
    },
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "resolveJsonModule": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "../src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
